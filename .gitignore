# ==============================================================================
# Monorepo Global .gitignore
# ==============================================================================

# Dependencies
node_modules/
/**/node_modules/
.pnpm-store
jspm_packages/

# Logs & Diagnostic reports
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Environment variables (JANGAN PERNAH DI-COMMIT)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
!*.env.example

# Build outputs (Frontend / Backend)
dist/
build/
out/
/**/dist/
/**/build/
.next/
.nuxt/

# TypeScript Cache
*.tsbuildinfo

# Test Coverage
coverage/
.nyc_output/
*.lcov

# Prisma
# (Jika Anda memakai SQLite untuk db lokal, un-comment db di bawah)
# *.db
# *.db-journal
# Folder generated client custom (jika bukan di node_modules)
**/src/generated/prisma/

# Caches
.eslintcache
.npm
.yarn
.parcel-cache
.cache/

# OS specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs and Editors
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo

# Miscellaneous
*.pem
*.tgz
